# Copy to <repo-root>/keystore.properties and fill in with real values.
# The real file is gitignored — never commit secrets.
#
# storeFile can be either an absolute path or a path relative to the
# project root.

storeFile=livecaptionn-upload.keystore
storePassword=REPLACE_ME
keyAlias=livecaptionn
keyPassword=REPLACE_ME
